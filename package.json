{
  "name": "chrome-autofill-architecture",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @autofill/web-test",
    "dev:web": "npm run dev -w @autofill/web-test",
    "build": "npm run build -ws --if-present",
    "build:web": "npm run build -w @autofill/web-test",
    "build:extension": "npm run build -w @autofill/extension",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc -b",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@tanstack/react-query": "^5.80.0",
    "clsx": "^2.1.1",
    "framer-motion": "^12.12.1",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.3.0",
    "zustand": "^5.0.5"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.319",
    "@types/node": "^22.15.21",
    "@types/react": "^19.1.5",
    "@types/react-dom": "^19.1.5",
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "@vitejs/plugin-react": "^4.5.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.27.0",
    "eslint-config-prettier": "^10.1.5",
    "postcss": "^8.5.3",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3",
    "vite": "^6.3.5"
  }
}
